{
  "name": "@euro-coins/source",
  "version": "0.1.0",
  "description": "Structured map of every euro coin design with metadata and ECB image URLs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "node --test --import tsx \"src/**/*.test.ts\"",
    "qa": "biome check .",
    "qa:fix": "biome check --write ."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mateuszsikora/euro-coins.git",
    "directory": "packages/source"
  },
  "license": "MIT",
  "author": "Mateusz Sikora",
  "homepage": "https://github.com/mateuszsikora/euro-coins/tree/main/packages/source",
  "bugs": {
    "url": "https://github.com/mateuszsikora/euro-coins/issues"
  },
  "keywords": ["euro", "coins", "numismatics", "ecb", "european-central-bank", "metadata"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
