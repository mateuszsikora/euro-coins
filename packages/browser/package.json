{
  "name": "@euro-coins/browser",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "download": "euro-coins download --output public/coins",
    "types": "euro-coins types --output src/types.d.ts",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "predev": "npm run download",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "qa": "biome check .",
    "qa:fix": "biome check --write ."
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@euro-coins/cli": "^0.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
