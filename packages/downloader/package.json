{
  "name": "@euro-coins/downloader",
  "version": "0.2.0",
  "description": "Download and normalize euro coin images from ECB",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "prepack": "npm run build",
    "build": "tsc --build",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "node --test --import tsx \"src/**/*.test.ts\"",
    "qa": "biome check .",
    "qa:fix": "biome check --write ."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mateuszsikora/euro-coins.git",
    "directory": "packages/downloader"
  },
  "license": "MIT",
  "author": "Mateusz Sikora",
  "homepage": "https://github.com/mateuszsikora/euro-coins/tree/main/packages/downloader",
  "bugs": {
    "url": "https://github.com/mateuszsikora/euro-coins/issues"
  },
  "keywords": ["euro", "coins", "downloader", "ecb", "sharp", "image-processing"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@euro-coins/source": "^0.2.0",
    "sharp": "^0.33.0"
  }
}
